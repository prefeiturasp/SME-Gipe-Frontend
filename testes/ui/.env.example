# ========================================
# Configurações de Banco de Dados
# ========================================
DB_USER=seu_usuario_db
DB_PASSWORD=sua_senha_db
DB_HOST=localhost
DB_DATABASE=gipe_qa

# ========================================
# Credenciais de Teste - API
# ========================================
# Usuário padrão para testes
API_USER_EMAIL=usuario.teste@prefeitura.sp.gov.br
API_USER_PASSWORD=Senha@123

# Usuário administrador (se necessário)
API_ADMIN_EMAIL=admin@prefeitura.sp.gov.br
API_ADMIN_PASSWORD=Admin@123

# Token JWT válido (opcional - use quando já tiver um token)
# Se definido, será usado no lugar do login tradicional
# Exemplo: API_AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
API_AUTH_TOKEN=

# ========================================
# Credenciais de Teste - UI
# ========================================
UI_USER_EMAIL=usuario.teste@prefeitura.sp.gov.br
UI_USER_PASSWORD=Senha@123

# ========================================
# URLs de Ambiente
# ========================================
# URL base da aplicação web
BASE_URL=https://qa-gipe.sme.prefeitura.sp.gov.br/

# URL base da API
API_BASE_URL=https://qa-gipe.sme.prefeitura.sp.gov.br/api-intercorrencias/v1

# ========================================
# Configurações de Teste
# ========================================
# Ambiente de execução (dev, qa, staging, prod)
TEST_ENV=qa

# Habilitar capturas de tela em falhas
ENABLE_SCREENSHOTS=true

# Habilitar gravação de vídeo
ENABLE_VIDEO=true

# Timeout padrão em milissegundos
DEFAULT_TIMEOUT=60000

# ========================================
# Cypress Cloud (opcional)
# ========================================
# CYPRESS_RECORD_KEY=sua_chave_aqui
# CYPRESS_PROJECT_ID=seu_project_id

# ========================================
# Allure Reports (opcional)
# ========================================
ALLURE_RESULTS_PATH=allure-results
ALLURE_REPORT_PATH=allure-report

# ========================================
# Tags para execução seletiva
# ========================================
# Exemplo: "not @skip and @smoke"
TAGS=not @skip

# ========================================
# Configurações de Retry
# ========================================
RETRY_RUN_MODE=2
RETRY_OPEN_MODE=0
