# ============================================================================
# CREDENCIAIS DE ACESSO - AMBIENTE QA GIPE (TEMPLATE)
# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env: cp .env.example .env
# 2. Preencha com as credenciais reais fornecidas pela equipe
# 3. NUNCA versione o arquivo .env (já está no .gitignore)
# ============================================================================

# ====================================
# PERFIL GIPE (Padrão) - Gestão/Admin
# ====================================
RF_GIPE=
SENHA_GIPE=

# ====================================
# PERFIL UE - Unidade Educacional
# ====================================
# Usado por: cadastro_ue.feature, consulta_filtro.js
RF_UE=
SENHA_UE=

# ====================================
# PERFIL CADASTRO OCORRÊNCIAS
# ====================================
# Usado por: cadastro_ocorrencias.js
RF_CADASTRO=
SENHA_CADASTRO=

# ====================================
# PERFIL DRE - Diretoria Regional
# ====================================
RF_DRE=
SENHA_DRE=

# ====================================
# PERFIL CARGA - Testes de Performance
# ====================================
# Usado por: gipe_carga.feature, alterar_senha.js, alteracao_email.js
CPF_CARGA=
SENHA_CARGA=

# ====================================
# CREDENCIAIS INVÁLIDAS (Testes Negativos)
# ====================================
RF_INVALIDO=
SENHA_INVALIDA=

# ====================================
# DADOS DE ESTUDANTES (Fixtures)
# ====================================
ALUNO_RA=
DATA_NASC=
EMAIL=

# ====================================
# UUIDs DE PROVAS (Testes API)
# ====================================
PROVA_TAI_ID=
PROVA_TAEB_ID=
PROVA_TAM_ID=

# ====================================
# UUIDs DE ALUNOS (Testes API)
# ====================================
ALUNO_UUID=
ALUNO_ESCOLA_UUID=

# ====================================
# TOKEN DE AUTENTICAÇÃO API (Diretor de Escola)
# ====================================
# Perfil: DIRETOR DE ESCOLA (código 3360)
# Obtenha o token válido com a equipe ou via comando: npm run cy:token
AUTH_TOKEN=

# Timeout padrão em milissegundos
DEFAULT_TIMEOUT=60000

# ========================================
# Cypress Cloud (opcional)
# ========================================
# CYPRESS_RECORD_KEY=sua_chave_aqui
# CYPRESS_PROJECT_ID=seu_project_id

# ========================================
# Allure Reports (opcional)
# ========================================
ALLURE_RESULTS_PATH=allure-results
ALLURE_REPORT_PATH=allure-report

# ========================================
# Tags para execução seletiva
# ========================================
# Exemplo: "not @skip and @smoke"
TAGS=not @skip

# ========================================
# Configurações de Retry
# ========================================
RETRY_RUN_MODE=2
RETRY_OPEN_MODE=0
